---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const inputClass =
  'w-full px-4 py-3 rounded-lg bg-surface-light dark:bg-surface border border-border-light dark:border-border text-text-primary-light dark:text-text-primary placeholder-text-secondary-light dark:placeholder-text-secondary focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors duration-200';

const labelClass =
  'block text-sm font-medium text-text-primary-light dark:text-text-primary mb-2';
---

<BaseLayout
  title="Contact"
  description="Have a project in mind or want to discuss ML engineering opportunities? Send me a message and I'll get back to you."
>
  <section class="max-w-2xl mx-auto px-4 md:px-6 py-20 md:py-24">
    <h1
      class="text-4xl font-bold tracking-tight text-text-primary-light dark:text-text-primary"
    >
      Get in Touch
    </h1>
    <p class="mt-4 text-body-lg text-text-secondary-light dark:text-text-secondary">
      Have a project in mind or want to discuss ML engineering opportunities? Send me a message
      and I'll get back to you.
    </p>

    {/* TODO: Replace PLACEHOLDER_ID with the form ID from https://formspree.io */}
    <form
      action="https://formspree.io/f/PLACEHOLDER_ID"
      method="POST"
      class="mt-10 space-y-6"
    >
      <div>
        <label for="name" class={labelClass}>
          Name <span class="text-accent-light dark:text-accent" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          aria-required="true"
          autocomplete="name"
          class={inputClass}
        />
      </div>

      <div>
        <label for="email" class={labelClass}>
          Email <span class="text-accent-light dark:text-accent" aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          aria-required="true"
          autocomplete="email"
          class={inputClass}
        />
      </div>

      <div>
        <label for="message" class={labelClass}>
          Message <span class="text-accent-light dark:text-accent" aria-hidden="true">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          aria-required="true"
          class={inputClass}></textarea>
      </div>

      <div>
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-accent-light dark:bg-accent text-primary-light dark:text-primary font-semibold hover:bg-accent-light-hover dark:hover:bg-accent-hover transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary-light dark:focus:ring-offset-primary"
        >
          Send Message
        </button>
      </div>
    </form>

    <div class="mt-16 pt-8 border-t border-border-light dark:border-border">
      <p
        class="text-sm font-mono uppercase tracking-wider text-text-secondary-light dark:text-text-secondary mb-4"
      >
        Or find me on
      </p>
      <SocialLinks size={22} gap="gap-6" />
    </div>
  </section>
</BaseLayout>
