---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/links';
---

<BaseLayout
  title="404 — Page Not Found"
  description="The page you're looking for doesn't exist or has been moved."
>
  <section
    class="max-w-2xl mx-auto px-4 md:px-6 py-24 md:py-32 flex flex-col items-center text-center"
  >
    <p class="font-mono text-accent-light dark:text-accent text-lg">404</p>
    <h1
      class="mt-4 text-4xl md:text-5xl font-bold tracking-tight text-text-primary-light dark:text-text-primary"
    >
      Page Not Found
    </h1>
    <p class="mt-6 text-body-lg text-text-secondary-light dark:text-text-secondary">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href={withBase('/')}
      class="mt-10 inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent-light dark:bg-accent text-primary-light dark:text-primary font-semibold hover:bg-accent-light-hover dark:hover:bg-accent-hover transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary-light dark:focus:ring-offset-primary"
    >
      Back to Home
    </a>
  </section>
</BaseLayout>
