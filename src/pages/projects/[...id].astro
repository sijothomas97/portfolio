---
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowRight, ExternalLink } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/links';

export async function getStaticPaths() {
  const all = await getCollection('projects');
  all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return all.map((project, idx) => ({
    params: { id: project.id },
    props: {
      project,
      prev: idx > 0 ? all[idx - 1] : null,
      next: idx < all.length - 1 ? all[idx + 1] : null,
    },
  }));
}

const { project, prev, next } = Astro.props;
const { Content } = await render(project);
const dateLabel = project.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
});

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: new URL(withBase('/'), Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Projects',
      item: new URL(withBase('/projects'), Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.data.title,
      item: canonical,
    },
  ],
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  ogImage={project.data.ogImage}
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <article class="max-w-3xl mx-auto px-4 md:px-6 py-16 md:py-20">
    <header class="mb-12">
      <a
        href={withBase('/projects')}
        class="inline-flex items-center gap-1 text-sm text-text-secondary-light dark:text-text-secondary hover:text-accent-light dark:hover:text-accent transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded"
      >
        <ArrowLeft size={16} aria-hidden="true" />
        All projects
      </a>

      <h1
        class="mt-6 text-4xl md:text-5xl font-bold tracking-tight text-text-primary-light dark:text-text-primary"
      >
        {project.data.title}
      </h1>

      <p class="mt-4 text-sm font-mono text-text-secondary-light dark:text-text-secondary">
        <time datetime={project.data.date.toISOString()}>{dateLabel}</time>
      </p>

      {
        project.data.tags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {project.data.tags.map((tag) => (
              <li class="inline-block px-3 py-1 rounded-full text-sm font-mono bg-accent-light/10 dark:bg-accent/10 text-accent-light dark:text-accent">
                {tag}
              </li>
            ))}
          </ul>
        )
      }

      {
        project.data.techStack.length > 0 && (
          <div class="mt-6">
            <p class="text-xs font-mono uppercase tracking-wider text-text-secondary-light dark:text-text-secondary mb-2">
              Tech stack
            </p>
            <ul class="flex flex-wrap gap-2">
              {project.data.techStack.map((tech) => (
                <li class="inline-block px-2.5 py-0.5 rounded-md text-xs font-mono border border-border-light dark:border-border text-text-secondary-light dark:text-text-secondary">
                  {tech}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        (project.data.github || project.data.liveUrl) && (
          <div class="mt-8 flex flex-wrap gap-3">
            {project.data.github && (
              <a
                href={project.data.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-accent-light dark:border-accent text-accent-light dark:text-accent text-sm font-medium hover:bg-accent-light/10 dark:hover:bg-accent/10 transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                  />
                </svg>
                View on GitHub
              </a>
            )}
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border-light dark:border-border text-text-primary-light dark:text-text-primary text-sm font-medium hover:border-accent-light dark:hover:border-accent transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
              >
                <ExternalLink size={16} aria-hidden="true" />
                Live demo
              </a>
            )}
          </div>
        )
      }
    </header>

    <div class="prose dark:prose-invert prose-headings:font-semibold max-w-none">
      <Content />
    </div>

    {
      (prev || next) && (
        <nav
          aria-label="Project navigation"
          class="mt-16 pt-8 border-t border-border-light dark:border-border grid grid-cols-2 gap-4"
        >
          <div>
            {prev && (
              <a
                href={withBase('/projects/' + prev.id)}
                class="group flex flex-col p-4 -m-4 rounded-lg hover:bg-surface-light dark:hover:bg-surface transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
              >
                <span class="inline-flex items-center gap-1 text-xs font-mono uppercase tracking-wider text-text-secondary-light dark:text-text-secondary">
                  <ArrowLeft size={14} aria-hidden="true" />
                  Previous
                </span>
                <span class="mt-2 text-text-primary-light dark:text-text-primary font-medium group-hover:text-accent-light dark:group-hover:text-accent transition-colors">
                  {prev.data.title}
                </span>
              </a>
            )}
          </div>
          <div class="text-right">
            {next && (
              <a
                href={withBase('/projects/' + next.id)}
                class="group flex flex-col items-end p-4 -m-4 rounded-lg hover:bg-surface-light dark:hover:bg-surface transition-colors focus:outline-none focus:ring-2 focus:ring-accent"
              >
                <span class="inline-flex items-center gap-1 text-xs font-mono uppercase tracking-wider text-text-secondary-light dark:text-text-secondary">
                  Next
                  <ArrowRight size={14} aria-hidden="true" />
                </span>
                <span class="mt-2 text-text-primary-light dark:text-text-primary font-medium group-hover:text-accent-light dark:group-hover:text-accent transition-colors">
                  {next.data.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>
