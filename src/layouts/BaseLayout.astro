---
import { withBase } from '../utils/links';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage = '/images/og-image.png',
  ogType = 'website',
  canonicalUrl,
} = Astro.props;

const fullTitle = `${title} | Sijo Thomas`;
const siteOrigin = Astro.site ? Astro.site.origin : 'https://sijothomas97.github.io';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site ?? siteOrigin).toString();
const ogImageUrl = `${siteOrigin}${withBase(ogImage)}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0F172A" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sijo Thomas" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sijo Thomas — Blog"
      href={withBase('/rss.xml')}
    />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Sijo Thomas" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          const mode = stored ?? (prefersLight ? 'light' : 'dark');
          if (mode === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
          }
        } catch (_e) {
          /* localStorage unavailable — keep server-rendered default */
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body
    class="bg-primary-light dark:bg-primary text-text-primary-light dark:text-text-primary font-sans antialiased min-h-screen flex flex-col"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-accent-light dark:focus:bg-accent focus:text-primary-light dark:focus:text-primary focus:font-semibold"
    >
      Skip to content
    </a>

    <Header />

    <main id="main-content" class="flex-1 pt-16">
      <slot />
    </main>

    <Footer />

    <BackToTop />
  </body>
</html>
