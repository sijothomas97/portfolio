---
import { withBase } from '../../utils/links';
import SocialLinks from '../SocialLinks.astro';
---

<section class="min-h-screen flex items-center px-4 md:px-6">
  <div class="max-w-6xl mx-auto w-full text-center">
    <h1
      class="hero-name text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight text-text-primary-light dark:text-text-primary"
    >
      Sijo Thomas
    </h1>
    <p
      class="hero-title mt-4 font-mono text-accent-light dark:text-accent text-lg sm:text-xl"
    >
      AI / ML Engineer
    </p>
    <p
      class="hero-description mx-auto mt-6 max-w-2xl text-body-lg text-text-secondary-light dark:text-text-secondary"
    >
      Building intelligent systems with GenAI, RAG, and cloud-native ML pipelines.
    </p>

    <div
      class="hero-ctas mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <a
        href={withBase('/projects')}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent-light dark:bg-accent text-primary-light dark:text-primary font-semibold hover:bg-accent-light-hover dark:hover:bg-accent-hover transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary-light dark:focus:ring-offset-primary"
      >
        View My Projects
      </a>
      <a
        href={withBase('/resume.pdf')}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-accent-light dark:border-accent text-accent-light dark:text-accent font-semibold hover:bg-accent-light/10 dark:hover:bg-accent/10 transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary-light dark:focus:ring-offset-primary"
      >
        Download CV
      </a>
    </div>

    <SocialLinks size={22} gap="gap-6" class="hero-social mt-10 justify-center" />
  </div>
</section>
