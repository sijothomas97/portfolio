---
import { withBase } from '../../utils/links';
import { Mail } from '@lucide/astro';

const iconLinkClass =
  'inline-flex p-1 text-text-secondary-light dark:text-text-secondary hover:text-accent-light dark:hover:text-accent transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded';
---

<section class="min-h-screen flex items-center px-4 md:px-6">
  <div class="max-w-6xl mx-auto w-full text-center">
    <h1
      class="hero-name text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight text-text-primary-light dark:text-text-primary"
    >
      Sijo Thomas
    </h1>
    <p
      class="hero-title mt-4 font-mono text-accent-light dark:text-accent text-lg sm:text-xl"
    >
      AI / ML Engineer
    </p>
    <p
      class="hero-description mx-auto mt-6 max-w-2xl text-body-lg text-text-secondary-light dark:text-text-secondary"
    >
      Building intelligent systems with GenAI, RAG, and cloud-native ML pipelines.
    </p>

    <div
      class="hero-ctas mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <a
        href={withBase('/projects')}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent-light dark:bg-accent text-primary-light dark:text-primary font-semibold hover:bg-accent-light-hover dark:hover:bg-accent-hover transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary-light dark:focus:ring-offset-primary"
      >
        View My Projects
      </a>
      <a
        href={withBase('/resume.pdf')}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-accent-light dark:border-accent text-accent-light dark:text-accent font-semibold hover:bg-accent-light/10 dark:hover:bg-accent/10 transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary-light dark:focus:ring-offset-primary"
      >
        Download CV
      </a>
    </div>

    <ul class="hero-social mt-10 flex items-center justify-center gap-6">
      <li>
        <a
          href="https://www.linkedin.com/in/sijothomas97/"
          aria-label="LinkedIn"
          target="_blank"
          rel="noopener noreferrer"
          class={iconLinkClass}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            />
          </svg>
        </a>
      </li>
      <li>
        <a
          href="https://github.com/sijothomas97"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
          class={iconLinkClass}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            />
          </svg>
        </a>
      </li>
      <li>
        <a href="mailto:sijo.thomas0097@gmail.com" aria-label="Email" class={iconLinkClass}>
          <Mail size={22} aria-hidden="true" />
        </a>
      </li>
    </ul>
  </div>
</section>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    import('gsap').then(({ gsap }) => {
      gsap.from('.hero-name', { opacity: 0, y: 30, duration: 0.8, delay: 0.2 });
      gsap.from('.hero-title', { opacity: 0, y: 30, duration: 0.8, delay: 0.4 });
      gsap.from('.hero-description', { opacity: 0, y: 30, duration: 0.8, delay: 0.6 });
      gsap.from('.hero-ctas', { opacity: 0, y: 30, duration: 0.8, delay: 0.8 });
      gsap.from('.hero-social', { opacity: 0, y: 30, duration: 0.8, delay: 1.0 });
    });
  }
</script>
