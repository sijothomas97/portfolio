---
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/links';
import ProjectCard from '../ProjectCard.astro';
import { ArrowRight } from '@lucide/astro';

const all = await getCollection('projects');
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.featuredOrder ?? Number.POSITIVE_INFINITY) - (b.data.featuredOrder ?? Number.POSITIVE_INFINITY));
---

<section
  aria-labelledby="featured-heading"
  class="reveal-on-scroll max-w-6xl mx-auto px-4 md:px-6 py-20 md:py-24"
>
  <h2
    id="featured-heading"
    class="text-3xl font-semibold text-text-primary-light dark:text-text-primary mb-4"
  >
    Featured Projects
  </h2>
  <p
    class="text-text-secondary-light dark:text-text-secondary text-body-lg mb-12 max-w-2xl"
  >
    A selection of projects showcasing my AI/ML expertise.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      featured.map((p) => (
        <ProjectCard
          id={p.id}
          title={p.data.title}
          description={p.data.description}
          tags={p.data.tags}
          thumbnail={p.data.thumbnail}
        />
      ))
    }
  </div>

  <div class="mt-12 flex justify-center">
    <a
      href={withBase('/projects')}
      class="inline-flex items-center gap-2 text-accent-light dark:text-accent font-medium hover:text-accent-light-hover dark:hover:text-accent-hover transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded"
    >
      View All Projects
      <ArrowRight size={18} aria-hidden="true" />
    </a>
  </div>
</section>
