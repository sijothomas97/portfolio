---
const categories = [
  {
    name: 'Languages & Frameworks',
    skills: ['Python', 'Flask', 'C#', '.NET', 'JavaScript', 'TypeScript', 'Node.js'],
  },
  {
    name: 'Databases',
    skills: ['MySQL', 'PostgreSQL', 'SQL Server', 'MongoDB'],
  },
  {
    name: 'Data Analysis & Visualisation',
    skills: ['Pandas', 'NumPy', 'Matplotlib', 'Seaborn', 'MS Excel'],
  },
  {
    name: 'ML & Deep Learning',
    skills: ['TensorFlow', 'PyTorch', 'Scikit-Learn', 'LangChain', 'Hugging Face'],
  },
  {
    name: 'Cloud Services',
    skills: ['AWS (SageMaker, Lambda, S3, Bedrock)', 'Azure'],
  },
  {
    name: 'Development Tools',
    skills: ['Git', 'Docker', 'VS Code', 'Jupyter Notebook', 'Linux'],
  },
];
---

<section
  aria-labelledby="skills-heading"
  class="reveal-on-scroll max-w-6xl mx-auto px-4 md:px-6 py-20 md:py-24"
>
  <h2
    id="skills-heading"
    class="text-3xl font-semibold text-text-primary-light dark:text-text-primary mb-4"
  >
    Technical Skills
  </h2>
  <p
    class="text-text-secondary-light dark:text-text-secondary text-body-lg mb-12 max-w-2xl"
  >
    Technologies and tools I use to build production ML systems.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      categories.map((category) => (
        <div class="bg-surface-light dark:bg-surface rounded-xl border border-border-light dark:border-border p-6">
          <h3 class="text-xl font-semibold text-text-primary-light dark:text-text-primary mb-4">
            {category.name}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <li class="inline-block px-3 py-1 rounded-full text-sm font-mono bg-accent-light/10 dark:bg-accent/10 text-accent-light dark:text-accent">
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
