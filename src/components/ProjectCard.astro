---
import { withBase } from '../utils/links';

interface Props {
  title: string;
  description: string;
  tags: string[];
  id: string;
  thumbnail?: string;
}

const { title, description, tags, id, thumbnail } = Astro.props;
const visibleTags = tags.slice(0, 4);
const tagData = tags.map((t) => t.toLowerCase()).join(',');
---

<article
  data-project
  data-tags={tagData}
  class="group relative bg-surface-light dark:bg-surface rounded-xl border border-border-light dark:border-border overflow-hidden transition-transform transition-shadow duration-200 hover:-translate-y-1 hover:shadow-lg hover:shadow-black/10 dark:hover:shadow-black/30 focus-within:ring-2 focus-within:ring-accent"
>
  <div class="aspect-[3/2] overflow-hidden">
    {
      thumbnail ? (
        <img
          src={thumbnail}
          alt=""
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      ) : (
        <div
          aria-hidden="true"
          class="w-full h-full bg-gradient-to-br from-accent-light/30 to-accent-light/5 dark:from-accent/30 dark:to-accent/5"
        />
      )
    }
  </div>

  <div class="p-6">
    <h3 class="text-xl font-semibold text-text-primary-light dark:text-text-primary">
      <a
        href={withBase('/projects/' + id)}
        class="focus:outline-none after:absolute after:inset-0 after:content-[''] after:rounded-xl"
      >
        {title}
      </a>
    </h3>
    <p
      class="mt-2 text-text-secondary-light dark:text-text-secondary text-body line-clamp-2"
    >
      {description}
    </p>
    {
      visibleTags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {visibleTags.map((tag) => (
            <li class="inline-block px-3 py-1 rounded-full text-sm font-mono bg-accent-light/10 dark:bg-accent/10 text-accent-light dark:text-accent">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>
