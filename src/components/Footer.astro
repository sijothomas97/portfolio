---
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer
  class="border-t border-border-light dark:border-border py-8 mt-12 bg-primary-light dark:bg-primary"
>
  <div
    class="max-w-6xl mx-auto px-4 md:px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <p class="text-sm text-text-secondary-light dark:text-text-secondary">
      &copy; {year} Sijo Thomas
    </p>
    <SocialLinks />
  </div>
</footer>
